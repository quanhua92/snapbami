# PostgreSQL
POSTGRES_USER=bamitools
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://bamitools:changeme@postgres:5432/bamitools

# Redis
REDIS_URL=redis://redis:6379/0

# RustFS (local S3)
S3_ENDPOINT_URL=http://rustfs:9000
S3_ACCESS_KEY=rustfsadmin
S3_SECRET_KEY=rustfsadmin
S3_PUBLIC_BUCKET=bamitools-public
S3_PRIVATE_BUCKET=bamitools-private
S3_REGION=us-east-1

# LLM (OpenAI-compatible)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Firebase (phase 06)
FIREBASE_SA_PATH=/etc/bamitools/firebase-service-account.json
