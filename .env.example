# PostgreSQL
POSTGRES_USER=snapbami
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://snapbami:changeme@postgres:5432/snapbami

# Redis
REDIS_URL=redis://redis:6379/0

# RustFS (local S3)
S3_ENDPOINT_URL=http://rustfs:9000
S3_ACCESS_KEY=rustfsadmin
S3_SECRET_KEY=rustfsadmin
S3_BUCKET=snapbami
S3_REGION=us-east-1

# LLM (OpenAI-compatible)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Firebase (phase 06)
FIREBASE_SA_PATH=/etc/snapbami/firebase-service-account.json
