# PostgreSQL
POSTGRES_USER=snapbami
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://snapbami:changeme@postgres:5432/snapbami

# Redis
REDIS_URL=redis://redis:6379/0

# LLM (OpenAI-compatible — works with OpenAI, DeepSeek, Ollama, etc.)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Firebase
FIREBASE_SA_PATH=/etc/snapbami/firebase-service-account.json

# Onidel S3
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=snapbami
S3_REGION=us-east-1
